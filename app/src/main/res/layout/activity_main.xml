<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingBottom="10dp"
            android:text="SAMSUNG  ·  MH19ZC2-12"
            android:textColor="@color/lcd_dim"
            android:letterSpacing="0.12"
            android:textSize="13sp" />

        <!-- LCD-панель -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/lcd_panel"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="● УВІМКНЕНО"
                android:textColor="@color/lcd_text"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvTemp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="25°"
                    android:textColor="@color/lcd_text"
                    android:textSize="64sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="end|center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="АВТО"
                        android:textColor="@color/lcd_text"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/tvFan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Вент: Авто"
                        android:textColor="@color/lcd_dim"
                        android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvFlags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:textColor="@color/lcd_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTimers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/lcd_dim"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- POWER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPower"
                style="@style/RemoteButton.Power"
                android:text="⏻  ЖИВЛЕННЯ" />
        </LinearLayout>

        <!-- Температура -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnTempDown"
                style="@style/RemoteButton"
                android:text="Темп −"
                android:textSize="18sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnTempUp"
                style="@style/RemoteButton"
                android:text="Темп +"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- Режим / Вентилятор -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnMode"
                style="@style/RemoteButton"
                android:text="Режим" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFan"
                style="@style/RemoteButton"
                android:text="Вентилятор" />
        </LinearLayout>

        <!-- Обдув / Турбо -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSwing"
                style="@style/RemoteButton"
                android:text="Обдув" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnTurbo"
                style="@style/RemoteButton"
                android:text="Турбо" />
        </LinearLayout>

        <!-- Тихо / Підсвітка -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnQuiet"
                style="@style/RemoteButton"
                android:text="Тихо" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnLight"
                style="@style/RemoteButton"
                android:text="Підсвітка" />
        </LinearLayout>

        <!-- Таймери -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnTimerOn"
                style="@style/RemoteButton"
                android:text="Таймер ON" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnTimerOff"
                style="@style/RemoteButton"
                android:text="Таймер OFF" />
        </LinearLayout>

        <!-- Сон / Скинути -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSleep"
                style="@style/RemoteButton"
                android:text="Сон" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnReset"
                style="@style/RemoteButton"
                android:text="Скинути" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
